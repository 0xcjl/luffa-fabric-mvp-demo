# Luffa Fabric MVP public demo environment
#
# API / Render
NODE_ENV=production
LAEL_HOST=0.0.0.0
LAEL_PUBLIC_CALLBACK_BASE_URL=https://luffa-fabric-mvp-api.onrender.com
LAEL_FRONTEND_URL=https://luffa-fabric-mvp-demo.vercel.app
ENABLE_LAEL_QA_RUNNER=false

# Mainnet real-value gate.
# Keep false for public browsing. Set true only for controlled small-value testing.
LAEL_ENABLE_MAINNET_EXECUTION=false
LAEL_MAINNET_MAX_AMOUNT_ETH=0.001

# Frontend / Vercel
NEXT_PUBLIC_LAEL_API_URL=https://luffa-fabric-mvp-api.onrender.com
