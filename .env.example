DATABASE_URL=./lael.db
LAEL_DB_PATH=./lael.db
LAEL_HOST=127.0.0.1
LAEL_PORT=3000
# Local Luffa App QR/WebView acceptance should use a stable HTTPS callback.
# Preferred local named Cloudflare Tunnel host:
# LAEL_PUBLIC_CALLBACK_BASE_URL=https://lael.clawworld.eu.cc
LAEL_PUBLIC_CALLBACK_BASE_URL=

BASE_RPC_URL=
BASE_MAINNET_RPC_URL=
SEPOLIA_RPC_URL=
POLYGON_RPC_URL=
SOLANA_RPC_URL=
ENDLESS_RPC_URL=

WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

USDC_BASE_SEPOLIA=
USDT_BASE_SEPOLIA=

ENABLE_SOLANA=true
ENABLE_EVM=true
ENABLE_ENDLESS=true
LAEL_SETTLEMENT_MODE=mock
LAEL_WALLET_NONCE_TTL_MS=600000
# Local QA Runner is intended for localhost-only development use.
ENABLE_LAEL_QA_RUNNER=true
